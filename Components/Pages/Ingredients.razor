@page "/ingredients"
@inject IIngredientService IngredientService
@rendermode InteractiveServer

<PageTitle>Ingrédients</PageTitle>

<RadzenText TextStyle="TextStyle.H4" class="mb-4">🥕 Gestion des Ingrédients</RadzenText>

<!-- Formulaire ajout / modification -->
<RadzenCard class="mb-4">
    <RadzenText TextStyle="TextStyle.H6" class="mb-3">
        @(_modeEdition ? "✏️ Modifier l'ingrédient" : "➕ Ajouter un ingrédient")
    </RadzenText>

    <RadzenRow Gap="1rem" AlignItems="AlignItems.End">
        <RadzenColumn Size="12" SizeMD="3">
            <RadzenFormField Text="Nom" Variant="Variant.Outlined" class="w-100">
                <RadzenTextBox @bind-Value="_form.Nom" Placeholder="Ex: Tomate" class="w-100" />
            </RadzenFormField>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3">
            <RadzenFormField Text="Unité" Variant="Variant.Outlined" class="w-100">
                <RadzenDropDown @bind-Value="_form.Unite" Data="@_unites" class="w-100" />
            </RadzenFormField>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3">
            <RadzenFormField Text="Calories par unité" Variant="Variant.Outlined" class="w-100">
                <RadzenNumeric @bind-Value="_form.CaloriesParUnite" Min="0" Step="0.1" class="w-100" />
            </RadzenFormField>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3">
            <RadzenButton Text="@(_modeEdition ? "Modifier" : "Ajouter")"
                          ButtonStyle="ButtonStyle.Primary"
                          Icon="save"
                          Click="Sauvegarder"
                          ButtonType="ButtonType.Button"
                          class="me-2" />
            @if (_modeEdition)
            {
                <RadzenButton Text="Annuler"
                               ButtonStyle="ButtonStyle.Light"
                                Click="Annuler"
                                ButtonType="ButtonType.Button" />
            }
        </RadzenColumn>
    </RadzenRow>

    @if (!string.IsNullOrEmpty(_message))
    {
        <RadzenAlert AlertStyle="AlertStyle.Success" class="mt-3">@_message</RadzenAlert>
    }
</RadzenCard>

<!-- Grille des ingrédients -->
<RadzenCard>
    <RadzenText TextStyle="TextStyle.H6" class="mb-3">📋 Liste des ingrédients</RadzenText>
    <RadzenDataGrid Data="@ingredients" TItem="Ingredient"
                    AllowSorting="true" AllowFiltering="true"
                    FilterMode="FilterMode.SimpleWithMenu"
                    AllowPaging="true" PageSize="10">
        <Columns>
            <RadzenDataGridColumn TItem="Ingredient" Property="Nom" Title="Nom" />
            <RadzenDataGridColumn TItem="Ingredient" Property="Unite" Title="Unité" Width="100px" />
            <RadzenDataGridColumn TItem="Ingredient" Property="CaloriesParUnite" Title="Cal / Unité" Width="140px">
                <Template Context="ing">@ing.CaloriesParUnite kcal</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Ingredient" Title="Actions" Sortable="false" Filterable="false" Width="130px">
                <Template Context="ing">
                    <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Warning" Size="ButtonSize.Small"
                                  Click="() => Editer(ing)" ButtonType="ButtonType.Button" class="me-1" />
                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                                  Click="() => Supprimer(ing.Id)" ButtonType="ButtonType.Button" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</RadzenCard>

@code {
    private List<Ingredient> ingredients = new();

    private Ingredient _form = new();

    private bool _modeEdition = false;

    private string _message = "";

    private readonly List<string> _unites = new() { "g", "ml", "pièce", "cuillère à soupe", "tasse" };
    protected override async Task OnInitializedAsync()
    {
        await ChargerIngredients();
    }
    private async Task ChargerIngredients()
    {
        ingredients = await IngredientService.GetAllAsync();
    }
    
    

    
    private async Task Sauvegarder()
    {
        if (string.IsNullOrWhiteSpace(_form.Nom))
            return;

        if (_modeEdition)
        {
            await IngredientService.ModifierAsync(_form);

            _message = $"✅ « {_form.Nom} » modifié avec succès.";
        }
        else
        {
            await IngredientService.AjouterAsync(_form);

            _message = $"✅ « {_form.Nom} » ajouté avec succès.";
        }

        await ChargerIngredients();

        Annuler();
    }

    private void Editer(Ingredient ing)
    {
        _form = new Ingredient
        {
            Id = ing.Id,
            Nom = ing.Nom,
            Unite = ing.Unite,
            CaloriesParUnite = ing.CaloriesParUnite
        };

        _modeEdition = true;

        _message = "";
    }



     private void Annuler()
    {
        _form = new Ingredient();

        _modeEdition = false;
    }

    private async Task Supprimer(int id)
    {
        await IngredientService.SupprimerAsync(id);

        await ChargerIngredients();

        _message = "🗑️ Ingrédient supprimé.";
    }
}